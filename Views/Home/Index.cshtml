@{
    ViewData["Title"] = "Home";
    ViewData["ActivePage"] = "Home";
}

<section class="hero-section">
    <div class="hero-content animate-up">
        <img src="~/images/logo.png" alt="Connect With Me" class="hero-logo" />

        <h1 class="welcome-label">Hello, Welcome!</h1>

        <p class="hero-subtitle">
            Let's connect across the web! Find all my important links, social accounts, and latest work right here.
        </p>

        <a asp-controller="Home" asp-action="Connect" class="cta-button">
            Connect Now <i class="fa-solid fa-arrow-right"></i>
        </a>
    </div>
</section>