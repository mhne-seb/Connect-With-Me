@{
    ViewData["Title"] = "About";
    ViewData["ActivePage"] = "About";
}

<section class="about-section">
    <div class="about-header animate-up">
        <h1 class="page-title">About <span class="highlight">Connect With Me</span></h1>
        <p class="page-subtitle">
            This system allows visitors to connect with me easily by<br />
            providing all my social links in one place.
        </p>
    </div>

    <div class="features-grid animate-up delay-1">
        <div class="feature-card">
            <div class="feature-icon">
                <i class="fa-regular fa-eye"></i>
            </div>
            <h3 class="feature-title">Simple Interface</h3>
            <p class="feature-desc">All links visible at a glance — no digging required.</p>
        </div>

        <div class="feature-card">
            <div class="feature-icon">
                <i class="fa-solid fa-link"></i>
            </div>
            <h3 class="feature-title">Official Logos</h3>
            <p class="feature-desc">Uses recognizable platform icons for easy identification.</p>
        </div>

        <div class="feature-card">
            <div class="feature-icon">
                <i class="fa-solid fa-mobile-screen"></i>
            </div>
            <h3 class="feature-title">Fully Responsive</h3>
            <p class="feature-desc">Looks great on desktop, tablet, and mobile devices.</p>
        </div>

        <div class="feature-card">
            <div class="feature-icon">
                <i class="fa-solid fa-bolt"></i>
            </div>
            <h3 class="feature-title">Quick Access</h3>
            <p class="feature-desc">Reach me instantly without searching multiple platforms.</p>
        </div>
    </div>

    <div class="highlight-banner animate-up delay-2">
        <h2 class="banner-title">One Link, All Platforms</h2>
        <p class="banner-desc">
            Visitors can reach me quickly without searching multiple platforms.
            Just one page, all connections.
        </p>
    </div>
</section>
